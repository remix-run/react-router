{
  "name": "@react-router/serve",
  "type": "module",
  "version": "8.1.0",
  "description": "Production application server for React Router",
  "bugs": {
    "url": "https://github.com/remix-run/react-router/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/remix-run/react-router",
    "directory": "packages/react-router-serve"
  },
  "license": "MIT",
  "exports": {
    "./package.json": "./package.json"
  },
  "bin": {
    "react-router-serve": "bin.cjs"
  },
  "scripts": {
    "build": "wireit",
    "typecheck": "tsc"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "../../pnpm-workspace.yaml",
        "*.ts",
        "bin.cjs",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ]
    }
  },
  "dependencies": {
    "@react-router/express": "workspace:*",
    "@react-router/node": "workspace:*",
    "@remix-run/node-fetch-server": "^0.13.3",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "morgan": "^1.10.1",
    "source-map-support": "^0.5.21"
  },
  "peerDependencies": {
    "react-router": "workspace:*"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.19.19",
    "@types/source-map-support": "^0.5.6",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "wireit": "catalog:"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "files": [
    "dist/",
    "bin.cjs",
    "CHANGELOG.md",
    "LICENSE.md",
    "README.md"
  ]
}
