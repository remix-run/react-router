{
  "extends": "../../tsconfig.base.json",
  "include": ["**/*.ts"],
  "exclude": ["dist", "node_modules"],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "jsx": "react",
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": ".",
    "outDir": "./dist"
  }
}
