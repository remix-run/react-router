{
  "extends": "../../tsconfig.base.json",
  "include": ["**/*.ts", "./package.json"],
  "exclude": ["dist", "**/node_modules/**", "__tests__"],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "declaration": true,
    "noEmit": true,
    "rootDir": ".",
    "outDir": "dist"
  }
}
