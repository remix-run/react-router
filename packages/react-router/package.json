{
  "name": "react-router",
  "type": "module",
  "version": "8.1.0",
  "description": "Declarative routing for React",
  "keywords": [
    "react",
    "router",
    "route",
    "routing",
    "history",
    "link"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/remix-run/react-router",
    "directory": "packages/react-router"
  },
  "license": "MIT",
  "author": "Remix Software <hello@remix.run>",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/production/index.d.ts",
      "react-server": {
        "module-sync": {
          "development": "./dist/development/index-react-server.js",
          "default": "./dist/production/index-react-server.js"
        },
        "development": "./dist/development/index-react-server.js",
        "default": "./dist/production/index-react-server.js"
      },
      "module-sync": {
        "development": "./dist/development/index.js",
        "default": "./dist/production/index.js"
      },
      "development": "./dist/development/index.js",
      "default": "./dist/production/index.js"
    },
    "./dom": {
      "types": "./dist/production/dom-export.d.ts",
      "module-sync": {
        "development": "./dist/development/dom-export.js",
        "default": "./dist/production/dom-export.js"
      },
      "development": "./dist/development/dom-export.js",
      "default": "./dist/production/dom-export.js"
    },
    "./internal": {
      "types": "./dist/development/lib/types/internal.d.ts"
    },
    "./internal/react-server-client": {
      "types": "./dist/production/index-react-server-client.d.ts",
      "module-sync": {
        "development": "./dist/development/index-react-server-client.js",
        "default": "./dist/production/index-react-server-client.js"
      },
      "development": "./dist/development/index-react-server-client.js",
      "default": "./dist/production/index-react-server-client.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "wireit",
    "prepublishOnly": "node ./scripts/copy-docs.mjs",
    "watch": "tsdown --watch & tsdown --config tsdown.config.rsc.ts --watch",
    "typecheck": "tsc"
  },
  "wireit": {
    "build": {
      "command": "premove dist && tsdown && tsdown --config tsdown.config.rsc.ts",
      "files": [
        "../../pnpm-workspace.yaml",
        "lib/**",
        "*.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ]
    }
  },
  "dependencies": {
    "cookie-es": "^3.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.19",
    "jest-environment-jsdom": "^30.4.1",
    "premove": "^4.0.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-test-renderer": "^19.2.7",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "undici": "^6.19.2",
    "wireit": "catalog:"
  },
  "peerDependencies": {
    "react": ">=19.2.7",
    "react-dom": ">=19.2.7"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "files": [
    "dist/",
    "docs/",
    "CHANGELOG.md",
    "LICENSE.md",
    "README.md"
  ],
  "engines": {
    "node": ">=22.22.0"
  }
}
