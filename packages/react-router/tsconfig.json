{
  "include": ["**/*.ts"],
  "exclude": ["dist", "__tests__", "node_modules"],
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "jsx": "react",

    "declaration": true,

    "skipLibCheck": true,

    "outDir": "dist",
    "rootDir": ".",
    "noEmit": true,
    "resolveJsonModule": true,
    "paths": {
      "react-router": ["./index.ts"],
      "react-router/internal/react-server-client": [
        "./index-react-server-client.ts"
      ]
    }
  }
}
