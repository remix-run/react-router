{
  "extends": "../../tsconfig.base.json",
  "include": ["**/*.ts", "./rsc-types.d.ts", "package.json"],
  "exclude": [
    "dist",
    "__tests__",
    "node_modules",
    "**/*-test.ts",
    "config/default-rsc-entries"
  ],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client", "@vitejs/plugin-rsc/types"],
    "jsx": "react",
    "outDir": "dist",
    "rootDir": ".",
    "noEmit": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  }
}
