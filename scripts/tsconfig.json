{
  "compilerOptions": {
    "lib": ["ES2024"],
    "target": "ES2024",
    "types": ["node"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "noUncheckedSideEffectImports": true,
    "erasableSyntaxOnly": true,
    "allowImportingTsExtensions": true
  },
  "include": ["./**/*.ts"]
}
